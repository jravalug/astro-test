---
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "Sobre mi";

const identity = {
  firstName: "Jose",
  country: "Cuba",
  occupation: "Profesor",
  hobbies: ["deportes", "manualidades", "peliculas"],
};

const skills = [
  "HTML",
  "CSS",
  "JavaScript",
  "React",
  "Astro",
  "Redacción de documentos",
];

const happy = true;
const finished = true;
const goal = 3;
---

<BaseLayout pageTitle={pageTitle}>
  <section class="max-w-2xl">
    <h2 class="text-2xl font-semibold mb-4">... ¡y mi nuevo sitio Astro!</h2>
    <p class="mb-4 text-gray-700 dark:text-gray-300">
      Estoy trabajando en el tutorial introductorio de Astro. Esta es la segunda
      página de mi sitio web, ¡y es la primera que he construido yo mismo!
    </p>
    <p class="mb-6 text-gray-700 dark:text-gray-300">
      Este sitio se irá actualizando a medida que vaya completando más partes
      del tutorial, ¡así que no dejes de visitarlo para ver cómo va mi viaje!
    </p>

    <h3 class="text-xl font-semibold mb-2">Mi identidad</h3>
    <ul class="space-y-2 mb-6">
      <li>Me llamo {identity.firstName}.</li>
      <li>Vivo en {identity.country} y trabajo como {identity.occupation}.</li>
      {
        identity.hobbies.length >= 2 && (
          <li>
            Dos de mis aficiones son: {identity.hobbies[0]} y{" "}
            {identity.hobbies[1]}
          </li>
        )
      }
    </ul>
    <h3 class="text-xl font-semibold mb-2">Mis habilidades</h3>
    <ul class="flex flex-wrap gap-2 mb-6">
      {
        skills.map((skill) => (
          <li class="px-3 py-1 bg-blue-100 dark:bg-blue-900 rounded">
            {skill}
          </li>
        ))
      }
    </ul>

    <p class="font-semibold mb-2">Estado:</p>
    <ul class="space-y-2">
      {happy && <li>Estoy feliz de aprender Astro!</li>}
      {finished && <li>He terminado este tutorial!</li>}
      {
        goal === 3 ? (
          <li>Mi objetivo es terminar en 3 días.</li>
        ) : (
          <li>Mi objetivo no son 3 días.</li>
        )
      }
    </ul>
  </section>
</BaseLayout>
