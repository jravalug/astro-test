---
const { title, url, pubDate, author } = Astro.props;
---

<div class="mb-2 p-3 border border-gray-200 dark:border-gray-700 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-800 transition">
  <a href={url} class="text-link hover:underline font-semibold">{title}</a>
  {author && <p class="text-sm text-gray-600 dark:text-gray-400 mt-1">{author} - {pubDate}</p>}
</div>
