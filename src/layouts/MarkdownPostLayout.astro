---
import BaseLayout from "./BaseLayout.astro";
import { fade } from "astro:transitions";
const { frontmatter } = Astro.props;
---

<BaseLayout pageTitle={frontmatter.title}>
  <p class="text-gray-600 dark:text-gray-300">{frontmatter.pubDate.toString().slice(0, 10)}</p>
  <p transition:animate={fade({ duration: "2s" })}>
    <em class="text-gray-700 dark:text-gray-200">{frontmatter.description}</em>
  </p>
  <p class="text-gray-800 dark:text-gray-200">Escrito por: <a href="/about" class="text-link hover:underline">{frontmatter.author}</a></p>
  <img src={frontmatter.image.url} width="300" alt={frontmatter.image.alt} loading="lazy" decoding="async" class="rounded-lg mb-4" />
  <div class="flex flex-wrap gap-2">
    {
      frontmatter.tags.map((tag) => (
        <p class="m-1 border border-dotted border-gray-300 rounded-lg px-4 py-2 text-[1.15rem] bg-tag-bg dark:bg-gray-700">
          <a href={`/tags/${tag}`} class="text-link hover:underline">{tag}</a>
        </p>
      ))
    }
  </div>
  <slot />
</BaseLayout>
